{
  "name": "symphony-forge",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "check:all": "turbo run check:all",
    "check:structural": "tsx linters/check-file-size.ts && tsx linters/check-imports.ts && tsx linters/check-boundaries.ts && tsx linters/check-naming.ts && tsx linters/check-docs.ts",
    "db:migrate": "pnpm --filter @symphony/api prisma:migrate",
    "db:seed": "pnpm --filter @symphony/api prisma:seed",
    "generate:api-client": "./scripts/generate-api-client.sh"
  },
  "devDependencies": {
    "tsx": "^4.19.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.2"
  }
}
