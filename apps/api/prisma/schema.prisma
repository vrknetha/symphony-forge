generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth ─────────────────────────────────────────────────────────────
// externalId = the `sub` claim from whichever OIDC provider PLAN.md specifies.
// Never store provider-specific fields here — keep it agnostic.

enum Role {
  ADMIN
  MEMBER
}

model User {
  id         String   @id @default(cuid())
  externalId String   @unique(map: "uq_users_external_id") @map("external_id")
  email      String   @unique(map: "uq_users_email")
  name       String
  role       Role     @default(MEMBER)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  ownedProjects Project[]       @relation("project_owner")
  memberships   ProjectMember[]

  @@map("users")
}

// ── Projects ─────────────────────────────────────────────────────────

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

model Project {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique(map: "uq_projects_slug")
  description String?
  status      ProjectStatus @default(ACTIVE)
  ownerId     String        @map("owner_id")
  deletedAt   DateTime?     @map("deleted_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  owner   User            @relation("project_owner", fields: [ownerId], references: [id])
  members ProjectMember[]

  @@index([deletedAt], map: "idx_projects_deleted_at")
  @@index([ownerId], map: "idx_projects_owner_id")
  @@map("projects")
}

enum MemberRole {
  OWNER
  EDITOR
  VIEWER
}

model ProjectMember {
  id        String     @id @default(cuid())
  projectId String     @map("project_id")
  userId    String     @map("user_id")
  role      MemberRole @default(EDITOR)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId], map: "uq_project_members_project_id_user_id")
  @@index([projectId], map: "idx_project_members_project_id")
  @@index([userId], map: "idx_project_members_user_id")
  @@map("project_members")
}

// ── Agent Keys ───────────────────────────────────────────────────────
// API keys for Symphony agents operating in worktrees.

model AgentKey {
  id           String    @id @default(cuid())
  name         String
  keyHash      String    @unique(map: "uq_agent_keys_key_hash") @map("key_hash")
  keyPrefix    String    @map("key_prefix")
  capabilities String[]
  active       Boolean   @default(true)
  lastUsedAt   DateTime? @map("last_used_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("agent_keys")
}
