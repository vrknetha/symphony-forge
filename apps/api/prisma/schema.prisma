datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// CONVENTION_CONFLICT: PLAN.md specifies a single schema.prisma for v1, while database.md prefers one Prisma schema file per domain.
model User {
  id          String          @id @default(cuid())
  azureOid    String          @unique @map("azure_oid")
  email       String          @unique
  name        String
  role        Role            @default(MEMBER)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  ownedProjects Project[]     @relation("ProjectOwner")
  memberships ProjectMember[]
  createdDocs Document[]

  @@map("users")
}

model Project {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String?
  status      ProjectStatus   @default(ACTIVE)
  ownerId     String          @map("owner_id")
  deletedAt   DateTime?       @map("deleted_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  owner       User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  members     ProjectMember[]
  documents   Document[]

  @@index([ownerId])
  @@index([deletedAt])
  @@map("projects")
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String      @map("project_id")
  userId    String      @map("user_id")
  role      MemberRole  @default(EDITOR)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  project   Project     @relation(fields: [projectId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([userId])
  @@unique([projectId, userId])
  @@map("project_members")
}

model Document {
  id               String      @id @default(cuid())
  title            String
  slug             String
  docType          DocType     @default(NOTES) @map("doc_type")
  projectId        String      @map("project_id")
  createdById      String      @map("created_by_id")
  proofDocSlug     String      @unique @map("proof_doc_slug")
  proofOwnerSecret String      @map("proof_owner_secret")
  proofAccessToken String      @map("proof_access_token")
  deletedAt        DateTime?   @map("deleted_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  project          Project     @relation(fields: [projectId], references: [id])
  createdBy        User        @relation(fields: [createdById], references: [id])

  @@index([projectId])
  @@index([createdById])
  @@index([deletedAt])
  @@unique([projectId, slug])
  @@map("documents")
}

model AgentKey {
  id           String     @id @default(cuid())
  name         String
  keyHash      String     @unique @map("key_hash")
  keyPrefix    String     @map("key_prefix")
  capabilities String[]
  active       Boolean    @default(true)
  lastUsedAt   DateTime?  @map("last_used_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("agent_keys")
}

enum Role {
  ADMIN
  MEMBER
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum MemberRole {
  OWNER
  EDITOR
  VIEWER
}

enum DocType {
  PLAN
  SPEC
  ADR
  NOTES
  RETROSPECTIVE
}
