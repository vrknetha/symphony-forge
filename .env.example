# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/symphony_forge
REDIS_URL=redis://localhost:6379

# ── Auth (OIDC — provider specified in PLAN.md) ─────────────────────
OIDC_ISSUER_URL=https://your-provider/.well-known/openid-configuration
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
JWT_SECRET=local-dev-jwt-secret-change-in-prod

# ── App ──────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
APP_ENCRYPTION_KEY=change-me-32-chars-minimum!!!!!!
API_PORT=3000
WEB_PORT=5173
