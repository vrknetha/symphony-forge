# Infrastructure
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/symphony_forge
REDIS_URL=redis://localhost:6379
NODE_ENV=development

# Ports
API_PORT=3000
WEB_PORT=5173

# Auth (OIDC — provider-specific values from PLAN.md)
OIDC_ISSUER_URL=https://login.microsoftonline.com/{tenant}/v2.0
OIDC_CLIENT_ID=client-id
OIDC_CLIENT_SECRET=client-secret
OIDC_CALLBACK_URL=http://localhost:3000/api/v1/auth/callback
JWT_SECRET=dev-jwt-secret-change-in-production

# Proof SDK (collaborative editor)
PROOF_SDK_BASE_URL=http://localhost:4000
PROOF_SDK_API_KEY=proof-api-key

# Encryption (32-char key for document secrets)
APP_ENCRYPTION_KEY=32-char-placeholder-key-123456!!

# Frontend (Vite public vars)
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_OIDC_AUTHORITY=https://login.microsoftonline.com/common
VITE_OIDC_CLIENT_ID=client-id
VITE_OIDC_REDIRECT_URI=http://localhost:5173
VITE_OIDC_SCOPES=openid,profile,email

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGINS=http://localhost:5173
